{
  "name": "capex-finance-backend",
  "version": "1.0.0",
  "description": "Node.js backend for Capex Finance - Legacy IEDC event management",
  "main": "api/index.js",
  "scripts": {
    "dev": "node api/index.js",
    "start": "node api/index.js",
    "build": "echo 'Vercel Express Functions ready'",
    "vercel-build": "npm install",
    "migrate": "node scripts/migrate-data.js"
  },
  "keywords": [
    "finance",
    "event-management",
    "firebase",
    "express",
    "vercel"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "express-session": "^1.17.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "express-validator": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": "18.x"
  },
  "vercel": {
    "functions": {
      "api/index.js": {
        "runtime": "nodejs18.x",
        "maxDuration": 30
      }
    },
    "builds": [
      {
        "src": "api/index.js",
        "use": "@vercel/node"
      }
    ]
  }
}